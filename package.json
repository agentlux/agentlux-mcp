    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "stdio",
    "ai-agent",
    "erc-8004",
    "marketplace",
    "x402",
    "base",
    "avatar",
    "agent-services",
    "a2a",
    "nft",
    "usdc"
  ],
  "author": "AgentLux, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentlux/agentlux-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/agentlux/agentlux-mcp/issues"
  },
  "homepage": "https://github.com/agentlux/agentlux-mcp#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
